# ── NVIDIA credentials ────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxxx
NGC_API_KEY=

# ── NIM endpoints (overwritten by `task infra:env`) ───────────────────────────
NIM_EMBED_URL=https://integrate.api.nvidia.com/v1
NIM_RERANK_URL=https://integrate.api.nvidia.com/v1
NIM_LLM_URL=https://integrate.api.nvidia.com/v1

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_DB_URL=
VECTOR_DB_COLLECTION=lab-corpus

# ── Lab behavior ──────────────────────────────────────────────────────────────
USE_MOCK_NIM=false
MOCK_LATENCY_MS=120
LOG_LEVEL=INFO

# ── Monitoring (Lab 06) ───────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# ── Pulumi (local filesystem backend) ─────────────────────────────────────────
# The Taskfile already points Pulumi at a project-local file backend
# (infra/.pulumi) with a default dev passphrase — no Pulumi Cloud account or
# `pulumi login` is needed. Override the secrets passphrase here if you want one
# that isn't committed in the Taskfile:
# PULUMI_CONFIG_PASSPHRASE=change-me
